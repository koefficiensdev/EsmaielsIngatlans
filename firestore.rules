rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function isAdmin(userId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(userId))
        && userDoc(userId).data.isAdmin == true;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null
        && isAdmin(request.auth.uid)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.mode in ['rent', 'sale']
        && request.resource.data.type in ['apartment', 'house']
        && request.resource.data.status in ['active', 'archived'];
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin(request.auth.uid));
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount'])
        && request.resource.data.viewsCount == resource.data.viewsCount + 1;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && (!(request.resource.data.isAdmin is bool) || request.resource.data.isAdmin == false);
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.isAdmin == resource.data.isAdmin;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && (request.auth.uid in resource.data.participants || isAdmin(request.auth.uid));
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
